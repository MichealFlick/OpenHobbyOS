prefix=/
exec_prefix=${prefix}
libdir=${exec_prefix}/lib
includedir=${prefix}/include

Name: X11
Description: OpenHobbyOS Xlib compatibility layer backed by upstream headers
URL: https://gitlab.freedesktop.org/xorg/lib/libX11/
Version: 1.8.13
Requires: xproto kbproto
Cflags: -I${includedir}
Libs: -L${libdir} -lX11
